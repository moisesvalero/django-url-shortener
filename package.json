{
  "name": "acortador",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i static/src/input.css -o static/output.css --minify",
    "watch:css": "tailwindcss -i static/src/input.css -o static/output.css --watch",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.0"
  },
  "lint-staged": {
    "*.{html,css,js,json,md}": [
      "prettier --write"
    ]
  }
}
