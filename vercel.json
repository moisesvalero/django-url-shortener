{
  "builds": [
    {
      "src": "acortador/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "acortador/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "acortador/wsgi.py"
    }
  ]
}
